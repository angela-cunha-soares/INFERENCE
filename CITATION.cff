title: "bwb -- Bayesian Water Balance framework"
message: "If you use this software, please cite it using the metadata below."
type: software
version: "0.1.0"
date-released: "2026-04-30"
license: MIT
repository-code: "https://github.com/angela-cunha-soares/INFERENCE"
authors:
  - family-names: "Cunha Soares"
    given-names: "Angela"
keywords:
